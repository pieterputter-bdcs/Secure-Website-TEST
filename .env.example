# Copy this file to .env and fill in the values before deploying

# REQUIRED in production — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Set to 'production' on your hosting platform
NODE_ENV=production

# Path to the SQLite database file on a persistent volume
DB_PATH=/data/app.db

# Port (most platforms set this automatically)
# PORT=3000
